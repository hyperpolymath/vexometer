// ══════════════════════════════════════════════════════════════════════════════
// ⚠️  NAME COINCIDENCE ALERT — READ THIS BEFORE DOING ANYTHING
// ══════════════════════════════════════════════════════════════════════════════
//
// This directory is named "vext" because the author was VEXED by Gemini and
// Copilot. The name comes from "vexed/irritating" — it is a component of the
// Vexometer (Irritation Surface Analyser for LLMs). It has NOTHING to do with
// the cryptographic "Vext" verification protocol.
//
//  ┌─ YOU ARE HERE ─────────────────────────────────────────────────────────┐
//  │  vexometer/vext — ISA component                                        │
//  │  Part of: Vexometer (Irritation Surface Analyser for LLMs)             │
//  │  Named: "vext" as in "vexed" — from irritation at Gemini + Copilot    │
//  │  Purpose: LLM behaviour analysis tool within the vexometer suite       │
//  │                                                                        │
//  │  This is a SUBDIRECTORY of the vexometer monorepo.                     │
//  │  GitHub: hyperpolymath/vexometer (monorepo)                            │
//  └────────────────────────────────────────────────────────────────────────┘
//
//  ┌─ NOT HERE — COMPLETELY DIFFERENT "VEXT" ───────────────────────────────┐
//  │  Vext — Verifiable, Extensible Communications Protocol                 │
//  │  BLAKE3 hash-chain feed integrity, Ed25519 signatures, dependent-type  │
//  │  proofs of algorithmic neutrality. A cryptographic verification tool.  │
//  │                                                                        │
//  │  Canonical spec:    hyperpolymath/vext  (top-level repo, NOT this dir) │
//  │  Burble consumer:   burble/server/lib/burble/verification/vext.ex      │
//  └────────────────────────────────────────────────────────────────────────┘
//
//  ┌─ ALSO NOT HERE — RENAMED ──────────────────────────────────────────────┐
//  │  vcs-ircd (formerly also named "vext")                                 │
//  │  A pooled IRC notification daemon for Git/VCS events. Rust/Tokio.      │
//  │  GitHub: hyperpolymath/vcs-ircd                                        │
//  └────────────────────────────────────────────────────────────────────────┘
//
// ══════════════════════════════════════════════════════════════════════════════

[identity]
name     = "vext"
kind     = "isa-component"
parent   = "vexometer"
path     = "vexometer/vext"

[purpose]
summary  = "LLM behaviour analysis component of the Vexometer irritation-surface analyser"
naming   = "Named 'vext' from 'vexed' — author was vexed by Gemini + Copilot. NOT the cryptographic Vext protocol."
relation = "ISA component. Part of vexometer monorepo. Unrelated to the Vext verification protocol."

[disambiguation]
cryptographic-vext  = "hyperpolymath/vext — the actual Vext protocol spec"
burble-consumer     = "burble/server/lib/burble/verification/vext.ex"
irc-daemon          = "hyperpolymath/vcs-ircd (formerly named 'vext')"

[invariants]
rules = [
  "This is an ISA component. It is NOT the Vext protocol spec or implementation.",
  "The name 'vext' here means 'vexed' (annoyed), NOT 'verifiable extensions'.",
  "Vexometer is the ISA (Irritation Surface Analyser) — vext is a sub-component.",
  "Do NOT confuse with hyperpolymath/vext (the cryptographic Vext protocol).",
]
