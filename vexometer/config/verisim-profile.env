# SPDX-License-Identifier: PMPL-1.0-or-later
# Repo-local VeriSim profile for vexometer benchmark dogfooding.
#
# This file is intentionally lightweight: it defines runtime behavior only.
# It does not vendor the VeriSimDB codebase and does not include any database data.

# Benchmark persistence backend (verisimdb | off)
VEXOMETER_BENCH_DB_BACKEND=verisimdb

# verisim endpoint mode:
#   auto     -> spin up repo-local sidecar if no VERISIM_API_URL is set
#   external -> use VEXOMETER_BENCH_VERISIM_EXTERNAL_URL
#   disabled -> skip publish step
VEXOMETER_BENCH_VERISIM_MODE=auto

# Sidecar bind settings (auto mode)
VEXOMETER_BENCH_VERISIM_HOST=127.0.0.1
VEXOMETER_BENCH_VERISIM_PORT_MIN=18080
VEXOMETER_BENCH_VERISIM_PORT_MAX=18999
VEXOMETER_BENCH_VERISIM_START_TIMEOUT_S=45

# Optional explicit verisim checkout location (if not on PATH as `verisim-api`)
# VERISIM_HOME=/var/mnt/eclipse/repos/nextgen-databases/verisimdb

# External mode endpoint
VEXOMETER_BENCH_VERISIM_EXTERNAL_URL=http://127.0.0.1:18080/api/v1
